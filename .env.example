# App
SCRATCH_APP_ENV=dev
SCRATCH_HTTP_ADDR=:8080
SCRATCH_LOG_LEVEL=info

# Postgres
SCRATCH_POSTGRES_DSN=postgres://user:pass@host:5432/db?sslmode=disable
SCRATCH_RUN_MIGRATIONS=true

# Valkey
SCRATCH_VALKEY_ADDR=localhost:6379
SCRATCH_VALKEY_USERNAME=
SCRATCH_VALKEY_PASSWORD=
SCRATCH_VALKEY_DB=0

# Auth (JWT / JWKS)
SCRATCH_AUTH_ENABLED=false
SCRATCH_AUTH_JWKS_ENDPOINT=https://your-issuer/.well-known/jwks.json
SCRATCH_AUTH_JWKS_REFRESH_MIN=10

# Rate Limiting
SCRATCH_RATE_LIMIT_PER_SECOND=0
SCRATCH_RATE_LIMIT_TTL_SEC=300

# OpenTelemetry
SCRATCH_TELEMETRY_ENABLED=false
SCRATCH_TELEMETRY_OTLP_ENDPOINT=localhost:4317

# TLS
SCRATCH_TLS_ENABLED=false
SCRATCH_TLS_CERT_FILE=
SCRATCH_TLS_KEY_FILE=

# CORS
SCRATCH_CORS_ORIGINS=*
SCRATCH_READ_TIMEOUT_SEC=10
SCRATCH_WRITE_TIMEOUT_SEC=30

# Feature Flags (fallback when Valkey unavailable)
SCRATCH_FEATURE_CACHE_TTL_SEC=30
SCRATCH_FEATURE_SOFT_DELETE=true
SCRATCH_FEATURE_AUDIT=false
SCRATCH_FEATURE_AUTH=false
SCRATCH_FEATURE_TELEMETRY=false
SCRATCH_FEATURE_VALKEY_CACHING=true
