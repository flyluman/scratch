    "definitions": {
        "httpapi.Envelope": {
            "type": "object",
            "properties": {
                "data": {},
                "error": {
                    "$ref": "#/definitions/httpapi.ErrBody"
                },
                "success": {
                    "type": "boolean"
                }
            }
        },
        "httpapi.ErrBody": {
            "type": "object",
